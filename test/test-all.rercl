    ; --- comparisons ---
    (equal? 1 1)                     #t
    (equal? 1 2)                     #f
    (= 1 2)                          #f
    (= 2 2)                          #t
    (!= 1 1)                         #f
    (!= 1 2)                         #t
    (< 1 2)                          #t
    (< 2 2)                          #f
    (< 3 2)                          #f
    (<= 0 1)                         #t
    (<= 1 1)                         #t
    (<= 2 1)                         #f
    (> 3 2)                          #t
    (> 3 3)                          #f
    (> 3 4)                          #f
    (>= 1 0)                         #t
    (>= 1 1)                         #t
    (>= 1 2)                         #f

