    ; --- lambda ---
    ((lambda (x) x) 0)            0             ; single parameter
    ((lambda (x y z) y) 1 2 3)    2             ; multiple parameters
    ((lambda (x y z) x y) 4 5 6)  5             ; multiple body exprs
    ;(lambda l l)                 (lambda l l)  ; variadic lambda
    ((lambda x x) 1 2 3)          (1 2 3)       ; variadic lambda
    (lambda 7)                    (*** lambda-syntax)
    (lambda (7))                  (*** lambda-syntax)


