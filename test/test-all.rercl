    ; --- symbols ---
    '()                        ()
    (quote ())                 ()
    (quote ||)                 ||
    (quote |!@#$|)             |!@#$|
    '|x|                       |x|
    undefined-sym              (*** unbound-variable)

    ; --- missing functor ---
    (())                             (*** empty-application)
    ; --- invalid functor ---
    (1)                              (*** not-a-procedure)

    ; --- if ---
    (if #t      )              (*** arity-error)
    (if #t 1 2)                1
    (if #f 1 2)                2
    (if #t 1 2 3)              (*** arity-error)
    (if 0 "yes" "no")          "yes"
    (if #t "ok")               "ok"
    (if #f "ok")               (|#%undef| if)

    ; --- cond ---
    (cond)                           (|#%undef| cond)
    (cond 1)                         (*** cond-clause-not-list)
    (cond (2))                       2
    (cond (#t 3))                    3
    (cond (#f 1) (#t 4))             4
    (cond (#t 1 2 3))                3        ; clause body is a begin-sequence
    (cond (#t 9) (oops 0))           9        ; short-circuit: later clause tests aren't evaluated

    ; |=>| is special only in a 3-element cond clause
    (cond (#f 0) (#f => -) (8))               8        ; arrow syntax: test is falsy
    (cond (#f 0) (7 => -) )                   -7       ; arrow syntax: test passed to functor
    (let ((=> "arrow")) (cond (=>)))          "arrow"  ; not a 3-element arrow clause
    (let ((=> "arrow")) (cond (#t =>)))       "arrow"  ; not a 3-element arrow clause
    (let ((=> "arrow")) (cond (#t => not)))   #f       ;  is a 3-element arrow clause
    (let ((=> "arrow")) (cond (#t => not 5))) 5        ; not a 3-element arrow clause

    ; |else| is special only when it is the first element of the last cond clause
    (let ((else "alpha")) (cond (else) (#t)))    "alpha"
    (let ((else "bravo")) (cond (#t else) (#t))) "bravo"
    (cond (#f 1) (else 5))                       5        ; else catch-all, taken
    (cond (else 7))                              7        ; else as the sole (last) clause
    (cond (#f) (else 6))                         6        ; test-only false falls through to else

    (cond (#f 1) +        )          (*** cond-clause-not-list)       ; clause is not a list
    (cond (#f 2) ()       )          (*** cond-clause-empty)          ; clause is an empty list
    (cond (#f 3) (else)   )          (*** cond-else-no-consequent)    ; else clause has no consequent



    ; --- and ---
    (and)                           #t
    (and #f)                        #f
    (and  1)                        1
    (and #f #f)                     #f
    (and #f  8)                     #f
    (and  2 #f)                     #f
    (and  3  9)                     9
    (and #f #f #f)                  #f
    (and #f #f  5)                  #f
    (and #f  1 #f)                  #f
    (and #f  2  6)                  #f
    (and  4 #f #f)                  #f
    (and  5 #f  7)                  #f
    (and  6  3 #f)                  #f
    (and  7  4  8)                  8

    ; --- or ---
    (or)                            #f
    (or #f)                         #f
    (or  1)                         1
    (or #f #f)                      #f
    (or #f  8)                      8
    (or  2 #f)                      2
    (or  3  9)                      3
    (or #f #f #f)                   #f
    (or #f #f  5)                   5
    (or #f  1 #f)                   1
    (or #f  2  6)                   2
    (or  4 #f #f)                   4
    (or  5 #f  7)                   5
    (or  6  3 #f)                   6
    (or  7  4  8)                   7

